# ╔═══════════════════════════════════════════════════════════╗
# ║ PetabyteAi — PRODUCTION .env template (Windows server)     ║
# ╚═══════════════════════════════════════════════════════════╝
# วิธีใช้: copy ไฟล์นี้เป็น  server\.env  แล้วเติมค่าจริง
#   - ค่า OpenAI / DB ใช้ชุดเดิมจาก .env ที่ใช้เทสได้แล้วก็ได้
#   - เปลี่ยน 2 ค่าหลักให้เป็น production:  NODE_ENV, ALLOWED_ORIGINS
# .env ห้าม commit ขึ้น git (อยู่ใน .gitignore แล้ว)

# ── โหมด production ───────────────────────────────────────────
# production = เปิด secure cookie (ต้องผ่าน HTTPS = ผ่าน tunnel) +
# บังคับว่าต้องตั้ง ALLOWED_ORIGINS (กันเปิด public แบบรับทุก origin)
NODE_ENV=production
PORT=3001

# ── Database (PostgreSQL บนเครือข่ายบริษัท) ───────────────────
# ถ้าเครื่อง Windows อยู่ใน LAN เดียวกับ DB → ต่อตรงได้ ไม่ต้อง VPN
# ถ้าอยู่นอกเครือข่าย → เครื่อง Windows ต้องต่อ VPN เอง
DB_HOST=192.168.69.125
DB_PORT=5432
DB_NAME=OpenAI_DB
DB_USER=postgres
DB_PASS=__ใส่รหัส_DB__

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=__sk-proj-...__
OPENAI_MODEL=gpt-4o
# เปลี่ยนรุ่นได้ที่ OPENAI_MODEL (เช่น gpt-5.5) — โค้ดรองรับ max_completion_tokens แล้ว
# OPENAI_TEMPERATURE: รุ่นเก่า (gpt-4o) ใส่ตัวเลขได้ เช่น 0.4 / รุ่นใหม่ (gpt-5.5, o-series)
# ไม่รับ custom temperature → ตั้งเป็นค่าว่าง (OPENAI_TEMPERATURE=) เพื่อไม่ให้ส่งไป
# ถ้าไม่ตั้ง ระบบ default 0.4 (และจะ auto-ปิดเองถ้ารุ่นนั้นไม่รับ)
OPENAI_TEMPERATURE=
OPENAI_ASSISTANT_ID=__asst-...__
OPENAI_VECTOR_STORE_ID=__vs-...__
OPENAI_ORG_ID=
OPENAI_ADMIN_KEY=
OPENAI_USAGE_SYNC_ENABLED=false

# ── Security ─────────────────────────────────────────────────
# ENCRYPTION_KEY ใช้ค่าเดิมจาก .env ที่ใช้อยู่ (ห้ามเปลี่ยน ไม่งั้น
# ข้อมูลที่เข้ารหัสไว้เดิมจะอ่านไม่ออก)
ENCRYPTION_KEY=__64-hex-เดิม__

# ── CORS: ใส่ URL สาธารณะที่เพื่อนใช้เข้า (สำคัญที่สุด!) ──────────
# ต้องตรงเป๊ะ รวม https:// และห้ามมี / ปิดท้าย
# ตัวอย่าง named tunnel โดเมนตัวเอง:
#   ALLOWED_ORIGINS=https://app.yourcompany.com
# ถ้ายังใช้ quick tunnel (URL สุ่ม) ต้องอัปเดตทุกครั้งที่ restart tunnel
ALLOWED_ORIGINS=https://__โดเมน-production-ของคุณ__

# ── ค่าปรับแต่ง (optional — มี default ในโค้ดอยู่แล้ว) ──────────
CHAT_RATE_LIMIT_PER_MIN=30
MAX_BALANCE=1000000
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
LOGIN_MAX_PER_15MIN=10
LOG_LEVEL=info
LOG_RETAIN_DAYS=14
