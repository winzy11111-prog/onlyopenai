# ╔═══════════════════════════════════════════════════════════╗
# ║ PetabyteAi — environment template                         ║
# ╚═══════════════════════════════════════════════════════════╝
# Copy to .env and fill in real values:   cp .env.example .env
# .env is gitignored — NEVER commit real keys.

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
# Assistant + Vector Store used by the chat/RAG layer
OPENAI_ASSISTANT_ID=asst_xxxxxxxxxxxxxxxxxxxx
OPENAI_VECTOR_STORE_ID=vs_xxxxxxxxxxxxxxxxxxxx

# Admin key (sk-admin-...) — server-only, powers usage sync. Optional.
OPENAI_ADMIN_KEY=
OPENAI_ORG_ID=
# Background usage sync: off by default. Manual /api/sync-now always works.
OPENAI_USAGE_SYNC_ENABLED=false
OPENAI_USAGE_SYNC_INTERVAL_MIN=15

# ── Server ───────────────────────────────────────────────────
PORT=3001
# development | production. In production ALLOWED_ORIGINS must be set or boot aborts.
NODE_ENV=development
# Comma-separated allowed browser origins. Empty in dev = allow all.
# For LAN testing add the host you serve from, e.g. http://192.168.69.50:3001
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
# Per-user requests/min for /api/chat
CHAT_RATE_LIMIT_PER_MIN=30
# Credit/balance sanity ceiling
MAX_BALANCE=1000000

# ── Database (PostgreSQL) ────────────────────────────────────
# If app + DB are on the SAME box use localhost. If using the shared
# DB server, point DB_HOST at its IP (e.g. 192.168.69.125).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=OpenAI_DB
DB_USER=postgres
DB_PASS=change-me-please
# Connection timeout (ms) — raise on slow/VPN networks
DB_CONNECT_TIMEOUT=15000

# ── Security ─────────────────────────────────────────────────
# AES-256 key for encrypted columns (tbl_project.project_api_key).
# 32 bytes hex (64 chars). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠ Do NOT change after data is encrypted without a re-encrypt migration.
ENCRYPTION_KEY=replace-with-64-hex-chars
# Account lockout after N failed logins, for M minutes
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
# Login brute-force throttle (per IP+username, 15-min window)
LOGIN_MAX_PER_15MIN=10

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_RETAIN_DAYS=14
# LOG_PRETTY=1
# LOG_FILE_DISABLE=1
