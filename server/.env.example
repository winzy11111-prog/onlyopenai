# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API Key — ใส่ key ตรงนี้เมื่อพร้อม
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Model ที่ใช้ (แนะนำ gpt-4o-mini เพื่อประหยัด cost)
OPENAI_MODEL=gpt-4o-mini

# Port ของ server (ไม่ต้องแก้ถ้าไม่มีการชน)
PORT=3001
